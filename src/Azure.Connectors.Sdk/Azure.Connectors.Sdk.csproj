<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Azure.Connectors.Sdk</PackageId>
    <Description>Lightweight SDK for building typed connectors for Azure</Description>
    <PackageTags>azure;connectors;sdk</PackageTags>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Azure.Connectors.Sdk.Tests, " />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Core" />
    <PackageReference Include="Azure.Identity" />
    <PackageReference Include="System.Text.Json" />
  </ItemGroup>

</Project>
